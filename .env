# ============================================================
# Environment Variables — copy this to your Ubuntu VM
# Never commit real credentials to Git
# ============================================================

# Elasticsearch
ES_HOST=http://localhost:9200

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=ids_db
ALERT_COLL=alerts

# Elasticsearch index names
SOURCE_INDEX=logs-*
ALERT_INDEX=ids-alerts

# Inference service
POLL_INTERVAL=10      # seconds between inference polls
BATCH_SIZE=500        # max log entries processed per poll

# API backend
API_HOST=0.0.0.0
API_PORT=8000
